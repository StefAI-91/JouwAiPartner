{
  "name": "knowledge-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write .",
    "test": "turbo test",
    "test:watch": "vitest --watch",
    "test:coverage": "turbo test -- --coverage",
    "format:check": "prettier --check .",
    "dep-graph": "node scripts/generate-dep-graph.js",
    "check:queries": "bash scripts/check-no-direct-supabase.sh",
    "check:features": "bash scripts/check-feature-drift.sh",
    "check:readmes": "bash scripts/check-readme-freshness.sh",
    "check:exports": "bash scripts/check-database-exports.sh",
    "detect-themes-batch": "tsx scripts/batch-detect-themes.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
